---
import { skillCategories } from "../data/skills";
---

<section id="skills" class="py-24">
    <div class="max-w-5xl mx-auto px-6">
        <!-- Section header -->
        <div class="reveal text-center mb-16">
            <h2
                class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3"
            >
                Tech Stack
            </h2>
            <div class="w-12 h-1 bg-primary-600 rounded-full mx-auto mb-4">
            </div>
            <p class="text-slate-500 dark:text-slate-400">
                Technologies I work with
            </p>
        </div>

        <!-- Skill categories -->
        <div class="grid md:grid-cols-3 gap-8">
            {
                skillCategories.map((category, catIdx) => (
                    <div
                        class="reveal"
                        style={`animation-delay: ${catIdx * 0.15}s;`}
                    >
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">
                            {category.title}
                        </h3>
                        <div class="w-8 h-0.5 bg-primary-500 rounded-full mb-5" />

                        <div class="flex flex-wrap gap-2.5">
                            {category.skills.map((skill) => (
                                <div class="group flex items-center gap-2.5 px-3.5 py-2.5 rounded-lg bg-white dark:bg-dark-tertiary border border-slate-100 dark:border-slate-700 hover:border-primary-300 dark:hover:border-primary-600 hover:shadow-md hover:shadow-primary-500/5 transition-all duration-300 hover:-translate-y-0.5 cursor-default">
                                    <span
                                        class="w-5 h-5 flex-shrink-0 text-slate-600 dark:text-slate-400 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors [&>svg]:w-full [&>svg]:h-full"
                                        set:html={skill.icon}
                                    />
                                    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">
                                        {skill.name}
                                    </span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
