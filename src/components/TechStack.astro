---
import { skillCategories } from "../data/skills";
---

<section id="skills" class="py-24">
    <div class="max-w-5xl mx-auto px-6">
        <!-- Section header -->
        <div class="reveal text-center mb-16 relative">
            <h2
                class="text-3xl sm:text-4xl font-black text-slate-900 dark:text-white mb-4"
            >
                Tech Stack
            </h2>
            <div class="w-20 h-1.5 bg-linear-to-r from-primary-600 to-accent-neon rounded-full mx-auto mb-4 drop-shadow-[0_0_10px_rgba(139,92,246,0.6)]">
            </div>
            <p class="text-slate-600 dark:text-slate-400 font-medium">
                Technologies I work with
            </p>
        </div>

        <!-- Skill categories -->
        <div class="grid md:grid-cols-3 gap-8">
            {
                skillCategories.map((category, catIdx) => (
                    <div
                        class="reveal relative z-10"
                        style={`animation-delay: ${catIdx * 0.15}s;`}
                    >
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">
                            {category.title}
                        </h3>
                        <div class="w-12 h-1 bg-linear-to-r from-primary-500 to-accent-neon rounded-full mb-6 drop-shadow-[0_0_8px_rgba(59,130,246,0.5)]" />

                        <div class="grid grid-cols-[repeat(auto-fill,minmax(80px,1fr))] gap-3">
                            {category.skills.map((skill) => (
                                <div class="group flex flex-col items-center justify-center p-3 rounded-2xl bg-white/40 dark:bg-slate-800/40 backdrop-blur-md border border-white/60 dark:border-white/10 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(59,130,246,0.15)] dark:hover:shadow-[0_10px_20px_rgba(139,92,246,0.2)] hover:border-primary-400 dark:hover:border-accent-neon cursor-default aspect-square relative overflow-hidden">
                                    <div class="absolute inset-0 bg-linear-to-b from-white/40 to-transparent dark:from-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 mix-blend-overlay pointer-events-none"></div>
                                    <img
                                        src={`https://skillicons.dev/icons?i=${skill.icon}`}
                                        alt={skill.name}
                                        title={skill.name}
                                        width="36"
                                        height="36"
                                        class="w-9 h-9 mb-2 transition-transform duration-500 group-hover:scale-110 drop-shadow-sm relative z-10"
                                        loading="lazy"
                                    />
                                    <span class="text-[10px] font-bold text-slate-700 dark:text-slate-300 transition-colors group-hover:text-primary-700 dark:group-hover:text-white text-center leading-tight tracking-wide relative z-10">
                                        {skill.name}
                                    </span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
