---
import { DottedMap } from "./ui/DottedMap";
import { ScrollReveal } from "./ui/ScrollReveal";
---

<section id="map" class="py-24 relative z-10 bg-slate-950">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      
      <!-- Text content -->
      <div class="w-full lg:w-1/3 flex flex-col gap-6">
        <ScrollReveal client:visible delay={0.1}>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-mono mb-4">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            IDN // Jember, East Java
          </div>
          <h2 class="text-4xl font-bold text-slate-100 tracking-tight">
            Operating Locally,<br/>Building Globally.
          </h2>
        </ScrollReveal>
        
        <ScrollReveal client:visible delay={0.2}>
          <p class="text-slate-400 text-lg leading-relaxed">
            Based in Indonesia, I collaborate with clients and teams worldwide to deliver high-quality digital products. 
            My time zone allows for excellent overlap with major global markets.
          </p>
        </ScrollReveal>
      </div>

      <!-- Map Graphic -->
      <div class="w-full lg:w-2/3 relative h-[400px] flex items-center justify-center">
        <!-- Radial gradient to fade edges -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_20%,#020617_70%)] z-10 pointer-events-none"></div>
        
        <!-- The Map -->
        <div class="absolute inset-0 opacity-60">
          <DottedMap client:visible cr={1} cx={1} cy={1} width={16} height={16} />
        </div>

        <!-- Indonesia Marker / Flag Pulse -->
        <div class="absolute z-20 flex flex-col items-center justify-center transform translate-x-24 translate-y-12">
          <!-- Radar rings -->
          <div class="absolute w-16 h-16 bg-emerald-500/20 rounded-full animate-ping"></div>
          <div class="absolute w-8 h-8 bg-emerald-500/40 rounded-full animate-pulse"></div>
          
          <!-- Core marker -->
          <div class="w-3 h-3 bg-emerald-400 rounded-full shadow-[0_0_15px_rgba(16,185,129,0.8)] z-30"></div>
          
          <!-- Label -->
          <div class="mt-4 px-2 py-1 bg-slate-900 border border-slate-700 rounded text-xs font-mono text-slate-300 backdrop-blur-sm z-30 flex items-center gap-2 shadow-xl">
            <span class="text-[10px]">🇮🇩</span> INDONESIA
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
