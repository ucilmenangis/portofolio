---
import { certifications } from "../data/certifications";
import { ScrollReveal } from "./ui/ScrollReveal";
import { TextAnimate } from "./ui/TextAnimate";
import { Particles } from "./ui/Particles";
import Icon from "./Icon.astro";

// --- Auto-generate PNG thumbnails from PDFs for mobile support ---
import { execSync } from "node:child_process";
import { existsSync, mkdirSync } from "node:fs";

try {
  if (!existsSync("public/images/certificate")) {
    mkdirSync("public/images/certificate", { recursive: true });
  }
  certifications.forEach(cert => {
    const pdfPath = "public" + cert.pdfUrl;
    const imgPath = pdfPath.replace("/pdf/", "/images/").replace(".pdf", ".png");
    // If the image doesn't exist, use macOS native 'sips' to render the PDF to a PNG
    if (!existsSync(imgPath) && existsSync(pdfPath)) {
      console.log("Generating thumbnail for:", pdfPath);
      // Generate a high-quality PNG of the first page
      execSync(`sips -s format png "${pdfPath}" --out "${imgPath}"`);
    }
  });
} catch (e) {
  console.error("Failed to generate PDF thumbnails:", e);
}
// -----------------------------------------------------------------
---

<section id="certifications" class="py-24 relative z-10 overflow-hidden bg-slate-950/50">
  <!-- Particles Background -->
  <div class="absolute inset-0 z-0 opacity-50 pointer-events-none">
    <Particles client:visible quantity={100} ease={80} color="#10b981" refresh />
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Section Header -->
    <div class="reveal flex flex-col items-center gap-4 mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight flex">
        <TextAnimate client:visible text="Certifications" delay={0.2} />
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl">
        Official credentials and verified achievements demonstrating my expertise.
      </p>
    </div>

    <!-- List Container -->
    <div class="flex flex-col gap-6 max-w-5xl mx-auto">
      {certifications.map((cert, i) => {
        const isIBM = cert.issuer.includes("IBM");
        const isAnthropic = cert.issuer.includes("Anthropic");
        const imgUrl = cert.pdfUrl.replace("/pdf/", "/images/").replace(".pdf", ".png");
        
        return (
          <ScrollReveal client:visible delay={0.1 * i} direction="up" className="w-full">
            <div class="group relative rounded-2xl border border-slate-800/50 bg-slate-900/30 backdrop-blur-sm p-4 hover:bg-slate-900/80 hover:border-emerald-500/40 transition-all duration-500 flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-8 overflow-hidden">
              
              {/* Left: Certificate Image Thumbnail */}
              <div class="block w-full md:w-64 shrink-0 aspect-[4/3] rounded-xl border border-slate-700/50 bg-slate-950 overflow-hidden relative">
                <!-- Click overlay -->
                <a href={cert.pdfUrl} target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-10 bg-transparent group-hover:bg-slate-900/10 transition-colors pointer-events-auto cursor-pointer flex items-center justify-center">
                   <div class="opacity-0 group-hover:opacity-100 transition-opacity bg-slate-900/80 backdrop-blur text-emerald-400 px-3 py-1.5 rounded-full text-xs font-semibold flex items-center gap-1.5 border border-emerald-500/30 shadow-xl transform scale-95 group-hover:scale-100">
                    <Icon name="arrow-right" class="w-3 h-3 -rotate-45" /> View PDF
                  </div>
                </a>
                
                <!-- Native Image (Flawless mobile support) -->
                <img 
                  src={imgUrl} 
                  alt={`${cert.title} Certificate`}
                  class="w-full h-full object-cover pointer-events-none opacity-80 group-hover:opacity-100 transition-opacity" 
                  loading="lazy"
                />
              </div>

              {/* Middle: Details */}
              <div class="flex-grow flex flex-col items-start w-full md:w-auto">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-lg bg-slate-800/80 flex items-center justify-center border border-slate-700 shrink-0">
                    {isIBM ? (
                      <img src="https://api.iconify.design/simple-icons:ibm.svg?color=%23ffffff" class="w-6 h-6" alt="IBM" />
                    ) : isAnthropic ? (
                      <img src="https://api.iconify.design/simple-icons:anthropic.svg?color=%23D97757" class="w-6 h-6" alt="Anthropic" />
                    ) : (
                      <Icon name="star" class="w-6 h-6 text-emerald-400" />
                    )}
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold text-slate-300">{cert.issuer}</span>
                    <span class="w-1 h-1 rounded-full bg-slate-600"></span>
                    <span class="text-sm text-slate-500">{cert.date}</span>
                  </div>
                </div>

                <h3 class="text-2xl font-bold text-slate-100 mb-2 group-hover:text-emerald-400 transition-colors">
                  {cert.title}
                </h3>
                
                <p class="text-slate-400 text-sm leading-relaxed mb-3">
                  {cert.description}
                </p>
                
                {cert.credentialId && (
                  <p class="text-sm font-mono text-slate-500">
                    ID: <span class="text-slate-400">{cert.credentialId}</span>
                  </p>
                )}
              </div>

              {/* Right: Actions */}
              <div class="flex flex-row md:flex-col gap-3 w-full md:w-auto shrink-0 mt-4 md:mt-0">
                <a 
                  href={cert.pdfUrl} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="flex-1 md:flex-none px-6 py-3 rounded-xl bg-slate-800 text-slate-200 text-sm font-semibold hover:bg-slate-700 hover:text-white transition-colors flex items-center justify-center gap-2 border border-slate-700 shadow-sm"
                >
                  Certificate
                </a>
                
                {cert.credentialUrl && (
                  <a 
                    href={cert.credentialUrl} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="flex-1 md:flex-none px-6 py-3 rounded-xl bg-emerald-500/10 text-emerald-400 text-sm font-semibold hover:bg-emerald-500/20 transition-colors flex items-center justify-center gap-2 border border-emerald-500/20 shadow-sm"
                  >
                    Verify 
                  </a>
                )}
              </div>
              
            </div>
          </ScrollReveal>
        );
      })}
    </div>
  </div>
</section>
