---
import Icon from "./Icon.astro";
---

<section id="contact" class="py-32 relative z-10 border-t border-slate-900">
  <div class="max-w-4xl mx-auto px-6 text-center">
    
    <div class="reveal flex flex-col items-center gap-8">
      <h2 class="text-5xl md:text-7xl font-bold text-slate-100 tracking-tight leading-none">
        Ready to build?
      </h2>
      
      <p class="text-xl text-slate-400 max-w-lg mx-auto font-medium">
        Whether you have a specific project in mind or just want to say hi, my inbox is always open.
      </p>

      <div class="mt-4">
        <a
          href="mailto:ucilmenangis@gmail.com"
          class="btn-primary inline-flex items-center gap-3 px-8 py-4 rounded-xl text-lg hover:scale-105 transition-transform"
        >
          <Icon name="mail" class="w-5 h-5" />
          Send me an email
        </a>
      </div>

      <!-- Clean Social Links -->
      <div class="flex items-center gap-6 mt-12">
        <a
          href="https://github.com/ucilmenangis"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-emerald-400 transition-colors"
          aria-label="GitHub"
        >
          <Icon name="github" class="w-6 h-6" />
        </a>
        <a
          href="https://www.linkedin.com/in/irfan-arrafi/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-emerald-400 transition-colors"
          aria-label="LinkedIn"
        >
          <Icon name="linkedin" class="w-6 h-6" />
        </a>
      </div>
    </div>

  </div>
</section>
