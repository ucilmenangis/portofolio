---

<section id="contact" class="py-24">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Section header -->
    <div class="reveal text-center mb-16">
      <h2
        class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3"
      >
        Get In Touch
      </h2>
      <div class="w-12 h-1 bg-primary-600 rounded-full mx-auto mb-4"></div>
      <p class="text-slate-500 dark:text-slate-400 max-w-lg mx-auto">
        Have a project in mind or want to collaborate? Feel free to reach out —
        I'm always open to new opportunities.
      </p>
    </div>

    <!-- Contact content -->
    <div class="reveal grid md:grid-cols-2 gap-8 items-center">
      <!-- Email CTA -->
      <div class="text-center md:text-left">
        <p class="text-lg text-slate-600 dark:text-slate-300 mb-6">
          The best way to reach me is via email. I'll get back to you as soon as
          possible.
        </p>
        <a
          href="mailto:ucilmenangis@gmail.com"
          class="inline-flex items-center gap-3 px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-primary-500/25 hover:-translate-y-0.5 text-lg"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
            ></path>
          </svg>
          Email Me
        </a>
      </div>

      <!-- Social links -->
      <div class="flex flex-col gap-3">
        <a
          href="https://github.com/ucilmenangis"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-dark-tertiary border border-slate-100 dark:border-slate-700 hover:border-primary-300 dark:hover:border-primary-600 hover:shadow-md transition-all duration-300"
        >
          <div
            class="w-10 h-10 rounded-lg bg-slate-900 dark:bg-white flex items-center justify-center flex-shrink-0"
          >
            <svg
              viewBox="0 0 24 24"
              class="w-5 h-5 text-white dark:text-slate-900"
              fill="currentColor"
              ><path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path></svg
            >
          </div>
          <div class="flex-1">
            <div
              class="text-sm font-semibold text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors"
            >
              GitHub
            </div>
            <div class="text-xs text-slate-400 dark:text-slate-500">
              @ucilmenangis
            </div>
          </div>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 text-slate-300 dark:text-slate-600 group-hover:text-primary-500 group-hover:translate-x-1 transition-all"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
          >
        </a>

        <a
          href="https://www.linkedin.com/in/irfan-arrafi/"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-dark-tertiary border border-slate-100 dark:border-slate-700 hover:border-primary-300 dark:hover:border-primary-600 hover:shadow-md transition-all duration-300"
        >
          <div
            class="w-10 h-10 rounded-lg bg-[#0A66C2] flex items-center justify-center flex-shrink-0"
          >
            <svg
              viewBox="0 0 24 24"
              class="w-5 h-5 text-white"
              fill="currentColor"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
          </div>
          <div class="flex-1">
            <div
              class="text-sm font-semibold text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors"
            >
              LinkedIn
            </div>
            <div class="text-xs text-slate-400 dark:text-slate-500">
              Irfan Ar-Rafi
            </div>
          </div>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 text-slate-300 dark:text-slate-600 group-hover:text-primary-500 group-hover:translate-x-1 transition-all"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
          >
        </a>

        <a
          href="mailto:ucilmenangis@gmail.com"
          class="group flex items-center gap-4 p-4 rounded-xl bg-white dark:bg-dark-tertiary border border-slate-100 dark:border-slate-700 hover:border-primary-300 dark:hover:border-primary-600 hover:shadow-md transition-all duration-300"
        >
          <div
            class="w-10 h-10 rounded-lg bg-primary-600 flex items-center justify-center flex-shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
          </div>
          <div class="flex-1">
            <div
              class="text-sm font-semibold text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors"
            >
              Email
            </div>
            <div class="text-xs text-slate-400 dark:text-slate-500">
              ucilmenangis@gmail.com
            </div>
          </div>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 text-slate-300 dark:text-slate-600 group-hover:text-primary-500 group-hover:translate-x-1 transition-all"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</section>
