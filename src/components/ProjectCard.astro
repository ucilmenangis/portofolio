---
import type { Project } from "../data/projects";
import Icon from "./Icon.astro";
import { SafariMockup } from "./ui/SafariMockup";
import { AvatarCircles } from "./ui/AvatarCircles";

interface Props {
  project: Project;
  index: number;
  className?: string;
  isFeatured?: boolean;
}

const { project, index, className = "", isFeatured = false } = Astro.props;
---

<div
  class={`group relative flex flex-col justify-between overflow-hidden rounded-3xl bg-slate-900/50 border border-slate-800/50 hover:border-emerald-500/30 transform hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(16,185,129,0.15)] transition-all duration-500 ease-out ${className}`}
>
  <!-- Content on top -->
  <div class="p-6 md:p-8 z-10 flex flex-col gap-4">
    <div class="flex flex-wrap gap-2">
      <AvatarCircles
        client:visible
        avatarUrls={project.tech.map(
          (t) =>
            `https://skillicons.dev/icons?i=${t === "tailwindcss" ? "tailwind" : t === "js" ? "javascript" : t}`,
        )}
      />
    </div>

    <h3
      class="font-bold text-slate-100 tracking-tight text-2xl md:text-3xl group-hover:text-emerald-400 transition-colors"
    >
      {project.title}
    </h3>

    <p class="text-slate-400 text-sm md:text-base max-w-lg">
      {project.description}
    </p>

    <!-- Links -->
    <div class="flex items-center gap-4 mt-2">
      {
        project.live && (
          <a
            href={project.live}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm font-semibold text-emerald-400 hover:text-emerald-300 transition-colors"
          >
            Live Demo <Icon name="external-link" class="w-4 h-4" />
          </a>
        )
      }
      {
        project.github && (
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-white transition-colors"
          >
            Source Code <Icon name="github" class="w-4 h-4" />
          </a>
        )
      }
    </div>
  </div>

  <!-- Visual Mockup at the bottom -->
  <div
    class="relative w-full flex-1 flex items-end justify-center px-6 md:px-12 pt-6 overflow-hidden"
  >
    <!-- Gradient overlay to blend bottom of mockup -->
    <div
      class="absolute inset-x-0 bottom-0 h-1/4 bg-gradient-to-t from-slate-900/80 to-transparent z-10 pointer-events-none"
    >
    </div>

    <div
      class="w-full max-w-3xl mx-auto transform translate-y-4 group-hover:-translate-y-2 transition-transform duration-700 ease-out"
    >
      <SafariMockup url={project.live || "local.dev"} className="shadow-2xl">
        <img
          src={project.image}
          alt={project.title}
          class="w-full h-auto max-h-[300px] object-cover object-top"
          loading="lazy"
        />
      </SafariMockup>
    </div>
  </div>
</div>
