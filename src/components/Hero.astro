---
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
import avatarImg from "../../public/images/avatar.png";
---

<section
    id="hero"
    class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16"
>
    <!-- Animated background mesh -->
    <div class="absolute inset-0 -z-10">
        <div
            class="absolute top-1/4 -left-20 w-72 h-72 bg-primary-400/20 dark:bg-primary-600/10 rounded-full blur-3xl animate-float"
        >
        </div>
        <div
            class="absolute bottom-1/4 -right-20 w-96 h-96 bg-primary-200/15 dark:bg-primary-700/10 rounded-full blur-3xl animate-float"
            style="animation-delay: -3s;"
        >
        </div>
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-160 h-160 bg-primary-300/10 dark:bg-primary-800/5 rounded-full blur-3xl"
        >
        </div>
        <!-- Grid pattern -->
        <div
            class="absolute inset-0 bg-[linear-gradient(rgba(48,54,79,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(48,54,79,0.04)_1px,transparent_1px)] bg-size-[60px_60px] dark:bg-[linear-gradient(rgba(172,186,196,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(172,186,196,0.05)_1px,transparent_1px)]"
        >
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 text-center">
        <!-- Greeting badge
        <div
            class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-50 dark:bg-primary-900/30 border border-primary-200 dark:border-primary-800 text-primary-700 dark:text-primary-300 text-sm font-medium mb-8"
        >
            <span
                class="inline-block w-2 h-2 rounded-full bg-primary-500 animate-pulse"
            ></span>
            Available for projects
        </div> -->

        <!-- Name -->
        <h1
            class="reveal text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black tracking-tight mb-4"
        >
            <span class="text-slate-900 dark:text-white">Hi, I'm </span>
            <span
                class="bg-linear-to-r from-primary-800 via-primary-600 to-primary-400 bg-clip-text text-transparent"
                >Irfan</span
            >
        </h1>

        <!-- Role -->
        <p
            class="reveal text-xl sm:text-2xl md:text-3xl font-semibold text-slate-700 dark:text-slate-300 mb-6"
            style="animation-delay: 0.1s;"
        >
            Fullstack Developer
        </p>

        <!-- Tagline -->
        <p
            class="reveal max-w-2xl mx-auto text-base sm:text-lg text-slate-500 dark:text-slate-400 mb-10 leading-relaxed"
            style="animation-delay: 0.2s;"
        >
            I build modern web and mobile applications with clean code and
            thoughtful design. Turning ideas into real, functional products.
        </p>

        <!-- CTA buttons -->
        <div
            class="reveal flex flex-wrap gap-4 justify-center"
            style="animation-delay: 0.3s;"
        >
            <a
                href="#projects"
                class="inline-flex items-center gap-2 px-7 py-3.5 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-primary-500/25 hover:-translate-y-0.5"
            >
                View My Work
                <Icon name="chevron-down" class="w-4 h-4 -rotate-90" />
            </a>
            <a
                href="mailto:ucilmenangis@gmail.com"
                class="inline-flex items-center gap-2 px-7 py-3.5 bg-primary-800 dark:bg-primary-50 text-white dark:text-primary-900 font-semibold rounded-xl hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5 border-none"
            >
                <Icon name="envelope" class="w-5 h-5" />
                Get In Touch
            </a>
        </div>

        <!-- Avatar -->
        <div
            class="reveal mt-16 flex justify-center"
            style="animation-delay: 0.4s;"
        >
            <div class="relative">
                <div
                    class="w-28 h-28 rounded-full bg-linear-to-br from-primary-400 to-primary-600 p-[3px] animate-pulse-ring"
                >
                    <div
                        class="w-full h-full rounded-full bg-surface-secondary dark:bg-dark-secondary flex items-center justify-center overflow-hidden"
                    >
                        <Image
                            src={avatarImg}
                            alt="Irfan Avatar"
                            class="w-full h-full object-cover"
                            loading="eager"
                        />
                    </div>
                </div>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div
            class="reveal mt-12 animate-bounce-slow"
            style="animation-delay: 0.5s;"
        >
            <Icon
                name="chevron-down"
                class="w-6 h-6 mx-auto text-slate-400 dark:text-slate-600"
            />
        </div>
    </div>
</section>
