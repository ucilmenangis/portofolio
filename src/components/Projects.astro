---
import { projects } from "../data/projects";
import ProjectCard from "./ProjectCard.astro";
import Icon from "./Icon.astro";
---

<section id="projects" class="py-32 relative z-10">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section Header (Stacked, no split, no eyebrow) -->
    <div class="reveal flex flex-col gap-4 mb-16 max-w-2xl">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight">
        Selected Work
      </h2>
      <p class="text-slate-400 text-lg">
        A collection of recent projects spanning web applications, digital systems, and custom server infrastructure.
      </p>
    </div>

    <!-- Bento Grid (3 items -> 1+2 split) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        projects.map((project, index) => {
          // 1+2 Split: First item spans full width
          const isFeatured = index === 0;
          const bentoClass = isFeatured ? "md:col-span-2 h-[400px] md:h-[500px]" : "md:col-span-1 h-[350px] md:h-[400px]";
          
          return (
            <ProjectCard
              project={project}
              index={index}
              className={bentoClass}
              isFeatured={isFeatured}
            />
          );
        })
      }
    </div>

    <!-- View More / GitHub Link -->
    <div class="reveal mt-12 flex justify-center">
      <a
        href="https://github.com/ucilmenangis"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost px-6 py-3 rounded-xl flex items-center gap-2"
      >
        <Icon name="github" class="w-5 h-5" />
        Explore more repositories
      </a>
    </div>
  </div>
</section>
