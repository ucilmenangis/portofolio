---
import { projects } from "../data/projects";
import ProjectCard from "./ProjectCard.astro";
import Icon from "./Icon.astro";
import { BlurFade } from "./ui/BlurFade";
import { ScrollReveal } from "./ui/ScrollReveal";
import { TextAnimate } from "./ui/TextAnimate";
import { VelocityScroll } from "./ui/VelocityScroll";
---

<div class="w-full bg-slate-950 border-y border-slate-900 py-12 mb-20 overflow-hidden">
  <VelocityScroll client:visible text="Fullstack • Laravel • React • Flutter • Tailwind • MySQL •" defaultVelocity={1} />
</div>

<section id="projects" class="py-16 relative z-10">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section Header -->
    <div class="flex flex-col gap-4 mb-16 max-w-2xl">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight flex">
        <TextAnimate client:visible text="Selected Work" delay={0.2} />
      </h2>
      <ScrollReveal client:load delay={0.2}>
        <p class="text-slate-400 text-lg">
          A collection of recent projects spanning web applications, digital systems, and custom server infrastructure.
        </p>
      </ScrollReveal>
    </div>

    <!-- Custom Responsive Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 mb-12">
      {
        projects.map((project, index) => {
          const isFeatured = index === 0;
          // Featured takes full width (2 cols), others take 1 col.
          const layoutClass = isFeatured 
            ? "lg:col-span-2 min-h-[450px] lg:min-h-[550px]" 
            : "col-span-1 min-h-[400px]";
          
          return (
            <BlurFade client:visible delay={0.2 + index * 0.1} className={layoutClass}>
              <ProjectCard
                project={project}
                index={index}
                className="w-full h-full"
                isFeatured={isFeatured}
              />
            </BlurFade>
          );
        })
      }
    </div>

    <!-- View More -->
    <ScrollReveal client:load delay={0.4} className="flex justify-center">
      <a
        href="https://github.com/ucilmenangis"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost px-6 py-3 rounded-xl flex items-center gap-2 hover:bg-slate-800 transition-colors"
      >
        <Icon name="github" class="w-5 h-5" />
        Explore more repositories
      </a>
    </ScrollReveal>
  </div>
</section>
