---
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../data/projects";
import Icon from "./Icon.astro";
---

<section
  id="projects"
  class="py-24 bg-surface-secondary dark:bg-dark-secondary"
>
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="reveal text-center mb-16">
      <h2
        class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3"
      >
        Projects
      </h2>
      <div class="w-12 h-1 bg-primary-600 rounded-full mx-auto mb-4"></div>
      <p class="text-slate-500 dark:text-slate-400">Some things I've built</p>
    </div>

    <!-- Project bento grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr"
    >
      {
        projects.map((project, index) => {
          // Bento layout logic: make first item span 2 columns
          const bentoClass =
            index === 0
              ? "md:col-span-2 lg:row-span-2 lg:col-span-2"
              : "md:col-span-1 lg:col-span-1";

          return (
            <ProjectCard
              project={project}
              index={index}
              className={bentoClass}
            />
          );
        })
      }
    </div>

    <!-- GitHub CTA -->
    <div class="reveal text-center mt-12">
      <a
        href="https://github.com/ucilmenangis"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-6 py-3 rounded-xl border-2 border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 font-semibold hover:border-primary-500 dark:hover:border-primary-500 hover:text-primary-600 dark:hover:text-primary-400 transition-all duration-300 hover:-translate-y-0.5"
      >
        <Icon name="github" class="w-5 h-5" />
        See More on GitHub
      </a>
    </div>
  </div>
</section>
