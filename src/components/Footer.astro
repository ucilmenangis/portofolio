---
import { Image } from "astro:assets";
import avatarImage from "../../public/images/avatar.png";
import Icon from "./Icon.astro";
---

<footer
  class="py-12 border-t border-slate-200/50 dark:border-white/10 bg-white/10 dark:bg-dark/10 backdrop-blur-xl relative z-10"
>
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Brand & About -->
      <div class="md:col-span-2">
        <a
          href="#"
          class="inline-flex items-center gap-3 hover:scale-105 transition-transform mb-6"
        >
          <Image
            src={avatarImage}
            alt="Irfan"
            class="w-12 h-12 object-cover rounded-full border-2 border-primary-500 shadow-[0_0_10px_rgba(59,130,246,0.4)]"
            loading="eager"
          />
          <span
            class="text-2xl font-black bg-linear-to-r from-primary-600 to-accent-neon bg-clip-text text-transparent tracking-tight"
            >Irfan</span
          >
        </a>
        <p
          class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed max-w-sm font-medium"
        >
          A Full Stack Developer focused on building clean, performant, and
          responsive web applications. Always eager to learn new technologies
          and take on new challenges.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-slate-900 dark:text-white font-bold mb-5 tracking-wide uppercase text-sm">
          Quick Links
        </h4>
        <ul class="space-y-3 text-sm font-medium text-slate-600 dark:text-slate-400">
          <li>
            <a
              href="#about"
              class="hover:text-primary-600 dark:hover:text-accent-neon transition-colors"
              >About</a
            >
          </li>
          <li>
            <a
              href="#skills"
              class="hover:text-primary-600 dark:hover:text-accent-neon transition-colors"
              >Skills</a
            >
          </li>
          <li>
            <a
              href="#projects"
              class="hover:text-primary-600 dark:hover:text-accent-neon transition-colors"
              >Projects</a
            >
          </li>
          <li>
            <a
              href="#timeline"
              class="hover:text-primary-600 dark:hover:text-accent-neon transition-colors"
              >Experience</a
            >
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-slate-900 dark:text-white font-bold mb-5 tracking-wide uppercase text-sm">
          Get In Touch
        </h4>
        <ul class="space-y-4 text-sm font-medium text-slate-600 dark:text-slate-400">
          <li class="flex items-start gap-3">
            <Icon
              name="map-pin"
              class="w-5 h-5 text-primary-500 dark:text-accent-neon shrink-0 mt-0.5 drop-shadow-sm"
            />
            <span>Jember, East Java, Indonesia</span>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="mail" class="w-5 h-5 text-primary-500 dark:text-accent-neon shrink-0 drop-shadow-sm" />
            <a
              href="mailto:ucilmenangis@gmail.com"
              class="hover:text-primary-600 dark:hover:text-accent-neon transition-colors"
              >ucilmenangis@gmail.com</a
            >
          </li>
          <li class="flex items-center gap-3 mt-2">
            <span
              class="inline-flex w-3 h-3 rounded-full bg-primary-500 shadow-[0_0_8px_rgba(59,130,246,0.6)] relative shrink-0"
            >
              <span
                class="absolute inline-flex w-full h-full rounded-full bg-primary-500 opacity-75 animate-ping"
              ></span>
            </span>
            <span class="text-slate-800 dark:text-slate-200 font-bold tracking-wide"
              >Available for work</span
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom footer -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-6 pt-8 border-t border-slate-200/50 dark:border-white/10"
    >
      <!-- Copyright -->
      <p
        class="text-sm font-medium text-slate-500 dark:text-slate-500 text-center sm:text-left"
      >
        &copy; {new Date().getFullYear()} Irfan. Built with
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-600 dark:text-accent-neon hover:text-primary-700 dark:hover:text-primary-400 transition-colors font-bold tracking-wide"
          >Astro</a
        >.
      </p>

      <!-- Social icons -->
      <div class="flex items-center justify-center gap-4">
        <a
          href="https://github.com/ucilmenangis"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="w-11 h-11 rounded-full flex items-center justify-center bg-white/60 dark:bg-slate-800/60 backdrop-blur-md border border-white dark:border-white/10 shadow-sm text-slate-700 dark:text-slate-300 hover:text-white dark:hover:text-white hover:bg-linear-to-r hover:from-primary-600 hover:to-accent-neon hover:shadow-[0_0_15px_rgba(59,130,246,0.5)] transition-all duration-300 hover:-translate-y-1"
        >
          <Icon name="github" class="w-5 h-5" />
        </a>
        <a
          href="https://www.linkedin.com/in/irfan-arrafi/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="w-11 h-11 rounded-full flex items-center justify-center bg-white/60 dark:bg-slate-800/60 backdrop-blur-md border border-white dark:border-white/10 shadow-sm text-slate-700 dark:text-slate-300 hover:text-white dark:hover:text-white hover:bg-linear-to-r hover:from-primary-600 hover:to-accent-neon hover:shadow-[0_0_15px_rgba(59,130,246,0.5)] transition-all duration-300 hover:-translate-y-1"
        >
          <Icon name="linkedin" class="w-5 h-5" />
        </a>
      </div>
    </div>
  </div>
</footer>
