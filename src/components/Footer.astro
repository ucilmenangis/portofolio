---
import { Image } from "astro:assets";
import avatarImage from "../../public/images/avatar.png";
import { SocialDock } from "./ui/SocialDock";
---

<footer class="py-12 bg-slate-950 relative z-10">
  <div
    class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-8"
  >
    <!-- Brand -->
    <a href="#" class="flex items-center gap-3 group">
      <Image
        src={avatarImage}
        alt="Irfan"
        class="w-10 h-10 object-cover rounded-full border border-slate-800 group-hover:border-emerald-500/50 transition-colors"
        loading="lazy"
      />
      <div class="flex flex-col">
        <span class="text-sm font-bold text-slate-200 tracking-tight"
          >Irfan Ar-Rafi</span
        >
        <span class="text-xs text-slate-400">Fullstack Developer</span>
      </div>
    </a>

    <!-- Magic UI Dock for Socials -->
    <div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50">
      <SocialDock client:visible />
    </div>

    <!-- Copyright -->
    <p class="text-sm font-medium text-slate-400 text-center">
      &copy; {new Date().getFullYear()} Just random person who love doing project with vibecode ❤️
    </p>
  </div>
</footer>
