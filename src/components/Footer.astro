---
import { Image } from "astro:assets";
import avatarImage from "../../public/images/avatar.png";
---

<footer class="py-8 border-t border-slate-900 bg-slate-950 relative z-10">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
    
    <!-- Brand -->
    <a href="#" class="flex items-center gap-3 group">
      <Image
        src={avatarImage}
        alt="Irfan"
        class="w-8 h-8 object-cover rounded-full border border-slate-800 group-hover:border-emerald-500/50 transition-colors"
        loading="lazy"
      />
      <span class="text-sm font-bold text-slate-300 tracking-tight">Irfan</span>
    </a>

    <!-- Copyright -->
    <p class="text-sm font-medium text-slate-500 text-center">
      &copy; {new Date().getFullYear()} Irfan. Built with Astro.
    </p>

  </div>
</footer>
