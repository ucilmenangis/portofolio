---
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
---

<section id="about" class="py-24 relative z-10">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section Header (Stacked) -->
    <div class="reveal flex flex-col gap-4 mb-16 max-w-2xl">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight">
        Background
      </h2>
      <p class="text-slate-400 text-lg">
        Bridging the gap between engineering and design.
      </p>
    </div>

    <!-- Content Grid -->
    <div class="reveal grid md:grid-cols-2 gap-16 items-start">
      <!-- Left: Bio -->
      <div class="flex flex-col gap-6">
        <p class="text-lg text-slate-300 leading-relaxed font-medium">
          I am a fullstack developer who loves turning ideas into real, functional products. Currently studying at <span class="text-emerald-400 font-semibold">Politeknik Negeri Jember</span> while freelancing as an independent developer.
        </p>
        <p class="text-lg text-slate-300 leading-relaxed font-medium">
          With experience spanning web services, server infrastructure, and mobile application development, I focus on writing clean code and building resilient systems.
        </p>
        
        <!-- Status Pills -->
        <div class="flex flex-wrap gap-4 mt-4">
          <div class="flex items-center gap-2 px-4 py-2 rounded-full border border-slate-700/50 bg-slate-800/30 text-sm font-medium text-slate-300">
            <Icon name="map-pin" class="w-4 h-4 text-emerald-400" />
            Indonesia
          </div>
          <div class="flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-sm font-medium text-emerald-300">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            Open to work
          </div>
        </div>
      </div>

      <!-- Right: Stats & GitHub -->
      <div class="flex flex-col gap-8">
        <!-- Minimal Stats Grid -->
        <div class="grid grid-cols-2 gap-6">
          <div class="flex flex-col gap-2 border-l-2 border-slate-800 pl-4">
            <span class="text-4xl font-bold text-slate-100">3+</span>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-widest">Projects</span>
          </div>
          <div class="flex flex-col gap-2 border-l-2 border-slate-800 pl-4">
            <span class="text-4xl font-bold text-slate-100">10+</span>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-widest">Technologies</span>
          </div>
        </div>

        <!-- GitHub Contributions -->
        <div class="hidden sm:flex flex-col gap-4 mt-4">
          <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-widest">Open Source Activity</h3>
          <div class="rounded-2xl glass-panel p-4 overflow-x-auto w-full">
            <Image
              src="https://ghchart.rshah.org/34d399/ucilmenangis"
              alt="GitHub Contribution Graph"
              inferSize={true}
              class="w-full min-w-[600px] opacity-80 hover:opacity-100 transition-opacity"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
