---
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
---

<section id="about" class="py-24 bg-surface-secondary dark:bg-dark-secondary">
    <div class="max-w-4xl mx-auto px-6">
        <!-- Section header -->
        <div class="reveal text-center mb-16">
            <h2
                class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3"
            >
                About Me
            </h2>
            <div class="w-12 h-1 bg-primary-600 rounded-full mx-auto mb-4">
            </div>
            <p class="text-slate-500 dark:text-slate-400">
                Get to know me a little better
            </p>
        </div>

        <!-- About content -->
        <div class="reveal grid md:grid-cols-[1fr_auto] gap-12 items-start">
            <!-- Bio text -->
            <div class="space-y-5">
                <p
                    class="text-lg leading-relaxed text-slate-600 dark:text-slate-300 text-justify"
                >
                    A passionate fullstack developer who loves turning ideas
                    into real projects. Currently studying at <span
                        class="font-semibold text-primary-600 dark:text-primary-400"
                        >Politeknik Negeri Jember</span
                    >
                    while freelancing as a developer. I enjoy working with both web
                    and mobile technologies, and I'm always eager to learn new things
                    and take on challenging projects.
                </p>
                <p
                    class="text-lg leading-relaxed text-slate-600 dark:text-slate-300 text-justify"
                >
                    With experience in web services and mobile application
                    development, I've worked on projects ranging from teaching
                    factory management systems to organization websites. I
                    believe in clean code, good design, and continuous learning.
                </p>

                <!-- Quick info chips -->
                <div class="flex flex-wrap gap-3 pt-2">
                    <span
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary-50 dark:bg-primary-900/20 border border-primary-100 dark:border-primary-800 text-primary-700 dark:text-primary-300 text-sm font-medium"
                    >
                        <Icon name="map-pin" class="w-4 h-4" />
                        Indonesia
                    </span>
                    <span
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary-50 dark:bg-primary-900/20 border border-primary-100 dark:border-primary-800 text-primary-700 dark:text-primary-300 text-sm font-medium"
                    >
                        <Icon name="graduation-cap" class="w-4 h-4" />
                        Student at Politeknik Negeri Jember
                    </span>
                    <span
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-100 dark:border-green-800 text-green-700 dark:text-green-300 text-sm font-medium"
                    >
                        <span
                            class="w-2 h-2 rounded-full bg-green-500 animate-pulse"
                        ></span>
                        Open to work
                    </span>
                </div>
            </div>

            <!-- Stats -->
            <div class="flex md:flex-col gap-4">
                <div
                    class="flex-1 p-5 rounded-xl bg-white dark:bg-dark-tertiary border border-slate-100 dark:border-slate-700 text-center min-w-[100px]"
                >
                    <div
                        class="text-3xl font-bold text-primary-600 dark:text-primary-100 mb-1"
                    >
                        3+
                    </div>
                    <div
                        class="text-xs font-medium text-slate-500 dark:text-slate-100 uppercase tracking-wider"
                    >
                        Projects
                    </div>
                </div>
                <div
                    class="flex-1 p-5 rounded-xl bg-white dark:bg-dark-tertiary border border-slate-100 dark:border-slate-700 text-center min-w-[100px]"
                >
                    <div
                        class="text-3xl font-bold text-primary-600 dark:text-primary-100 mb-1"
                    >
                        1+
                    </div>
                    <div
                        class="text-xs font-medium text-slate-500 dark:text-slate-100 uppercase tracking-wider"
                    >
                        Years Exp
                    </div>
                </div>
                <div
                    class="flex-1 p-5 rounded-xl bg-white dark:bg-dark-tertiary border border-slate-100 dark:border-slate-700 text-center min-w-[100px]"
                >
                    <div
                        class="text-3xl font-bold text-primary-600 dark:text-primary-100 mb-1"
                    >
                        10+
                    </div>
                    <div
                        class="text-xs font-medium text-slate-500 dark:text-slate-100 uppercase tracking-wider"
                    >
                        Technologies
                    </div>
                </div>
            </div>
        </div>

        <!-- GitHub Contributions -->
        <div class="reveal mt-16 w-full max-w-4xl mx-auto hidden sm:block">
            <h3
                class="text-xl font-bold text-slate-900 dark:text-white mb-6 text-center"
            >
                GitHub Contributions
            </h3>
            <div
                class="rounded-xl border border-slate-200 dark:border-slate-700/50 bg-white/50 dark:bg-slate-800/30 backdrop-blur-sm p-6 overflow-x-auto hover:shadow-lg transition-all duration-300"
            >
                <Image
                    src="https://ghchart.rshah.org/40c463/ucilmenangis"
                    alt="GitHub Contribution Graph"
                    inferSize={true}
                    class="w-full min-w-[700px] mx-auto filter dark:opacity-90 saturate-150 contrast-125 transition-all duration-300 hover:scale-[1.01]"
                    loading="lazy"
                />
            </div>
        </div>
    </div>
</section>
