---
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
import { NumberTicker } from "./ui/NumberTicker";
import { AvatarCircles } from "./ui/AvatarCircles";
import { Globe } from "./ui/Globe";
import { ScrollReveal } from "./ui/ScrollReveal";
import { TextAnimate } from "./ui/TextAnimate";
import { AnimatedGridPattern } from "./ui/AnimatedGridPattern";

const techAvatars = [
  "https://skillicons.dev/icons?i=laravel",
  "https://skillicons.dev/icons?i=flutter",
  "https://skillicons.dev/icons?i=react",
  "https://skillicons.dev/icons?i=tailwind",
];
---

<section id="about" class="py-24 relative z-10">
  <div class="max-w-7xl mx-auto px-6">
    <AnimatedGridPattern client:visible className="opacity-40" />
    <!-- Section Header (Stacked) -->
    <div class="flex flex-col gap-4 mb-16 max-w-2xl relative z-10">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight flex">
        <TextAnimate client:visible text="Background" delay={0.2} />
      </h2>
      <ScrollReveal client:load delay={0.2}>
        <p class="text-slate-400 text-lg">
          Bridging the gap between engineering and design.
        </p>
      </ScrollReveal>
    </div>

    <!-- Content Grid -->
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Left: Bio -->
      <ScrollReveal client:load delay={0.3} className="flex flex-col gap-6">
        <p class="text-lg text-slate-300 leading-relaxed font-medium">
          I am a fullstack developer who loves turning ideas into real, functional products. Currently studying at <span class="text-emerald-400 font-semibold">Politeknik Negeri Jember</span> while freelancing as an independent developer.
        </p>
        <p class="text-lg text-slate-300 leading-relaxed font-medium">
          With experience spanning web services, server infrastructure, and mobile application development, I focus on writing clean code and building resilient systems.
        </p>
        
        <!-- Status Pills -->
        <div class="flex flex-wrap gap-4 mt-4">
          <div class="flex items-center gap-2 px-4 py-2 rounded-full border border-slate-700/50 bg-slate-800/30 text-sm font-medium text-slate-300">
            <Icon name="map-pin" class="w-4 h-4 text-emerald-400" />
            Indonesia
          </div>
          <div class="flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-sm font-medium text-emerald-300">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            Open to work
          </div>
        </div>
      </ScrollReveal>

      <!-- Right: Stats & Map -->
      <div class="flex flex-col gap-8">
        <!-- Minimal Stats Grid -->
        <ScrollReveal client:load delay={0.4} className="grid grid-cols-2 gap-6">
          <div class="flex flex-col gap-2 border-l-2 border-slate-800 pl-4">
            <span class="text-4xl font-bold text-slate-100">
              <NumberTicker client:visible value={3} />+
            </span>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-widest">Projects</span>
          </div>
          <div class="flex flex-col gap-2 border-l-2 border-slate-800 pl-4">
            <span class="text-4xl font-bold text-slate-100">
              <NumberTicker client:visible value={10} delay={0.2} />+
            </span>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-widest">Technologies</span>
            <div class="mt-2">
              <AvatarCircles client:visible numPeople={6} avatarUrls={techAvatars} />
            </div>
          </div>
        </ScrollReveal>

        <!-- Globe Map -->
        <ScrollReveal client:load delay={0.5} className="flex flex-col gap-4 mt-4">
          <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-widest">Base of Operations</h3>
          <div class="rounded-3xl glass-panel overflow-hidden w-full h-[300px] relative border border-slate-800 bg-slate-950/50">
            <Globe client:visible className="mt-8 scale-150" />
            
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-slate-950/20 pointer-events-none"></div>
            <div class="absolute bottom-4 left-4 right-4 flex justify-between items-end">
              <div class="px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-mono font-medium backdrop-blur-md">
                LAT -8.17 | LNG 113.7
              </div>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </div>
</section>
