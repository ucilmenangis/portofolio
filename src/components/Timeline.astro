---
import { timeline as timelineItems } from "../data/timeline";
import { skillNames } from "../data/skills";
import Icon from "./Icon.astro";
import { ScrollReveal } from "./ui/ScrollReveal";
import { TextAnimate } from "./ui/TextAnimate";
---

<section id="timeline" class="py-24 relative z-10 overflow-hidden">
  <div class="max-w-5xl mx-auto px-6 relative">
    <!-- Section Header -->
    <div class="flex flex-col gap-4 mb-24 max-w-2xl text-center mx-auto items-center">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight flex">
        <TextAnimate client:visible text="Experience" delay={0.2} />
      </h2>
      <ScrollReveal client:load delay={0.2}>
        <p class="text-slate-400 text-lg">
          My professional and academic journey.
        </p>
      </ScrollReveal>
    </div>

    <!-- Timeline Container -->
    <div class="relative">
      <!-- Central Line (Dynamic glowing) -->
      <div class="absolute left-[20px] md:left-1/2 top-0 bottom-0 w-[2px] bg-slate-800/80 transform md:-translate-x-1/2">
        <div class="absolute top-0 w-full h-64 bg-gradient-to-b from-transparent via-emerald-500 to-transparent animate-[pulse_4s_ease-in-out_infinite]"></div>
      </div>

      <div class="flex flex-col gap-12 md:gap-24 relative">
        {
          timelineItems.map((item, index) => {
            const isLeft = index % 2 === 0;
            return (
              <ScrollReveal
                client:visible
                delay={0.2}
                className={`relative flex flex-col md:flex-row items-start md:items-center ${isLeft ? 'md:justify-start' : 'md:justify-end'} group w-full`}
              >
                {/* Timeline node */}
                <div class="absolute left-[20px] md:left-1/2 top-2 md:top-1/2 w-5 h-5 rounded-full border-4 border-slate-950 bg-slate-800 group-hover:bg-emerald-400 transition-colors duration-500 z-10 transform -translate-x-1/2 md:-translate-y-1/2 shadow-[0_0_10px_rgba(0,0,0,0.5)] group-hover:shadow-[0_0_15px_rgba(16,185,129,0.5)]"></div>

                {/* Content Card */}
                <div class={`w-full md:w-[45%] pl-14 md:pl-0 ${isLeft ? 'md:pr-14 md:text-right' : 'md:pl-14 md:text-left'}`}>
                  <div class={`flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2 ${isLeft ? 'md:justify-end' : 'md:justify-start'}`}>
                    <h3 class="text-xl font-bold text-slate-100 group-hover:text-emerald-300 transition-colors">
                      {item.title}
                    </h3>
                    <span class="text-sm font-mono text-emerald-500/80 uppercase tracking-widest">
                      {item.period}
                    </span>
                  </div>

                  <div class={`flex items-center gap-2 text-slate-400 font-medium mb-4 ${isLeft ? 'md:justify-end' : 'md:justify-start'}`}>
                    <span>{item.organization}</span>
                    {item.location && (
                      <>
                        <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                        <span>{item.location}</span>
                      </>
                    )}
                  </div>

                  <p class={`text-slate-300 leading-relaxed mb-6 font-medium ${isLeft ? 'md:ml-auto' : ''}`}>
                    {item.description}
                  </p>

                  {item.tech && item.tech.length > 0 && (
                    <div class={`flex flex-wrap gap-2 ${isLeft ? 'md:justify-end' : 'md:justify-start'}`}>
                      {item.tech.map((t) => (
                        <span class="px-2.5 py-1 text-xs font-mono font-medium rounded-md bg-slate-900 border border-slate-800 text-slate-400 uppercase tracking-wide hover:bg-slate-800 hover:text-emerald-400 transition-colors cursor-default">
                          {skillNames[t] || t.toUpperCase()}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </ScrollReveal>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
