---
import { timeline as timelineItems } from "../data/timeline";
import { skillNames } from "../data/skills";
import Icon from "./Icon.astro";
---

<section id="timeline" class="py-24 relative z-10">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Section Header (Stacked) -->
    <div class="reveal flex flex-col gap-4 mb-16 max-w-2xl">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight">
        Experience
      </h2>
      <p class="text-slate-400 text-lg">
        My professional and academic journey.
      </p>
    </div>

    <!-- Minimal Timeline List -->
    <div class="flex flex-col gap-12 border-l border-slate-800 ml-4 md:ml-8 pl-8 md:pl-12 relative">
      {
        timelineItems.map((item, index) => {
          const isWork = item.type === "work";

          return (
            <div
              class="reveal relative group"
              style={`animation-delay: ${index * 0.1}s;`}
            >
              <!-- Timeline node -->
              <div class="absolute -left-[41px] md:-left-[57px] top-1 w-5 h-5 rounded-full border-4 border-slate-950 bg-slate-800 group-hover:bg-emerald-400 transition-colors duration-300"></div>

              <div class="flex flex-col gap-2">
                <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-1">
                  <h3 class="text-xl font-bold text-slate-100 group-hover:text-emerald-300 transition-colors">
                    {item.title}
                  </h3>
                  <span class="text-sm font-mono text-emerald-500/80 uppercase tracking-widest">
                    {item.period}
                  </span>
                </div>

                <div class="flex items-center gap-2 text-slate-400 font-medium mb-3">
                  <span>{item.organization}</span>
                  {item.location && (
                    <>
                      <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                      <span>{item.location}</span>
                    </>
                  )}
                </div>

                <p class="text-slate-300 leading-relaxed max-w-2xl mb-4 font-medium">
                  {item.description}
                </p>

                {item.tech && item.tech.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-2">
                    {item.tech.map((t) => (
                      <span class="px-2.5 py-1 text-xs font-mono font-medium rounded-md bg-slate-900 border border-slate-800 text-slate-400 uppercase tracking-wide">
                        {skillNames[t] || t.toUpperCase()}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
