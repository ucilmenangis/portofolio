---
import { timeline as timelineItems } from "../data/timeline";
---

<section
  id="timeline"
  class="py-24 bg-surface-secondary dark:bg-dark-secondary"
>
  <div class="max-w-3xl mx-auto px-6">
    <!-- Section header -->
    <div class="reveal text-center mb-16">
      <h2
        class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3"
      >
        Experience & Education
      </h2>
      <div class="w-12 h-1 bg-primary-600 rounded-full mx-auto mb-4"></div>
      <p class="text-slate-500 dark:text-slate-400">My journey so far</p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div
        class="absolute left-[19px] top-2 bottom-2 w-px bg-slate-200 dark:bg-slate-700 md:left-1/2 md:-translate-x-px"
      >
      </div>

      <div class="space-y-10">
        {
          timelineItems.map((item, index) => {
            const isWork = item.type === "work";
            const isLeft = index % 2 === 0;

            return (
              <div
                class={`reveal relative flex items-start gap-6 md:gap-0 ${isLeft ? "md:flex-row" : "md:flex-row-reverse"}`}
                style={`animation-delay: ${index * 0.1}s;`}
              >
                {/* Marker dot */}
                <div class="relative z-10 flex-shrink-0 md:absolute md:left-1/2 md:-translate-x-1/2">
                  <div
                    class={`w-10 h-10 rounded-full border-4 ${isWork ? "border-primary-500 bg-primary-50 dark:bg-primary-950" : "border-emerald-500 bg-emerald-50 dark:bg-emerald-950"} flex items-center justify-center`}
                  >
                    {isWork ? (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-4 h-4 text-primary-600 dark:text-primary-400"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0"
                        />
                      </svg>
                    ) : (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-4 h-4 text-emerald-600 dark:text-emerald-400"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"
                        />
                      </svg>
                    )}
                  </div>
                </div>

                {/* Content card */}
                <div
                  class={`flex-1 md:w-[calc(50%-40px)] ${isLeft ? "md:pr-12" : "md:pl-12"}`}
                >
                  <div class="p-5 rounded-xl bg-white dark:bg-dark-tertiary border border-slate-100 dark:border-slate-700 hover:shadow-lg hover:shadow-slate-200/50 dark:hover:shadow-slate-900/50 transition-all duration-300">
                    {/* Header */}
                    <div class="flex items-center justify-between flex-wrap gap-2 mb-3">
                      <span
                        class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold uppercase tracking-wider ${isWork ? "bg-primary-50 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300" : "bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300"}`}
                      >
                        {isWork ? "Work" : "Education"}
                      </span>
                      <span class="text-xs font-medium text-slate-400 dark:text-slate-500">
                        {item.period}
                      </span>
                    </div>

                    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-1">
                      {item.title}
                    </h3>
                    <p class="text-sm font-semibold text-primary-600 dark:text-primary-400 mb-1">
                      {item.organization}
                    </p>

                    {item.location && (
                      <p class="flex items-center gap-1.5 text-xs text-slate-400 dark:text-slate-500 mb-3">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="w-3.5 h-3.5"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                          />
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                          />
                        </svg>
                        {item.location}
                      </p>
                    )}

                    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-3">
                      {item.description}
                    </p>

                    {/* Tags */}
                    {item.tags && item.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {item.tags.map((tag) => (
                          <span class="px-2 py-0.5 text-xs font-medium rounded bg-slate-50 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
