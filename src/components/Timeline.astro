---
import { timeline as timelineItems } from "../data/timeline";
import { skillNames } from "../data/skills";
import Icon from "./Icon.astro";
import { ScrollReveal } from "./ui/ScrollReveal";
import { TextAnimate } from "./ui/TextAnimate";
import { AvatarCircles } from "./ui/AvatarCircles";
import { ScrollLine } from "./ui/ScrollLine";
import { ScrollHighlight } from "./ui/ScrollHighlight";
import { Particles } from "./ui/Particles";
---

<section id="timeline" class="py-24 relative z-10 overflow-hidden">
  <!-- Particles Background -->
  <div class="absolute inset-0 z-0 opacity-50 pointer-events-none">
    <Particles client:visible quantity={100} ease={80} color="#10b981" refresh />
  </div>
  
  <div class="max-w-5xl mx-auto px-6 relative z-10">
    <!-- Section Header -->
    <div class="reveal flex flex-col items-center gap-4 mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight flex">
        <TextAnimate client:visible text="Experience" delay={0.2} />
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl">
        A timeline of my professional journey, education, and the roles that shaped my technical expertise.
      </p>
    </div>

    <!-- Timeline Container -->
    <div class="relative">
      <!-- Central Line (Dynamic scroll following) -->
      <ScrollLine client:visible className="left-[20px] md:left-[50%]" />

      <div class="flex flex-col gap-12 md:gap-24 relative">
        {
          timelineItems.map((item, index) => {
            const isLeft = index % 2 === 0;
            return (
              <ScrollReveal
                client:visible
                className={`relative flex flex-col md:flex-row items-start md:items-center ${isLeft ? 'md:justify-start' : 'md:justify-end'} group w-full`}
              >
                {/* Timeline node */}
                <div class="absolute left-[20px] md:left-1/2 top-2 md:top-1/2 w-5 h-5 rounded-full border-4 border-slate-950 bg-slate-800 group-hover:bg-emerald-400 transition-colors duration-500 z-10 transform -translate-x-1/2 md:-translate-y-1/2 shadow-[0_0_10px_rgba(0,0,0,0.5)] group-hover:shadow-[0_0_15px_rgba(16,185,129,0.5)]"></div>

                {/* Content Card */}
                <div class={`w-full md:w-[45%] pl-14 md:pl-0 ${isLeft ? 'md:pr-14 md:text-right' : 'md:pl-14 md:text-left'}`}>
                  <ScrollHighlight client:visible>
                    <div class={`flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2 ${isLeft ? 'md:justify-end' : 'md:justify-start'}`}>
                      <h3 class="text-xl font-bold text-slate-100 group-hover:text-emerald-300 transition-colors">
                        {item.title}
                      </h3>
                      <span class="text-sm font-mono text-emerald-500/80 uppercase tracking-widest">
                        {item.period}
                      </span>
                    </div>

                    <div class={`flex flex-wrap items-center gap-2 text-slate-400 font-medium mb-4 ${isLeft ? 'md:flex-row-reverse md:justify-start' : 'md:justify-start'}`}>
                      {item.logo && (
                        <img src={item.logo} alt={item.organization} class="w-6 h-6 rounded-full bg-slate-800 object-cover shrink-0" />
                      )}
                      <span class={isLeft ? 'md:text-right' : 'md:text-left'}>{item.organization}</span>
                      {item.location && (
                        <>
                          <span class="w-1 h-1 rounded-full bg-slate-700 shrink-0"></span>
                          <span class={`text-sm ${isLeft ? 'md:text-right' : 'md:text-left'}`}>{item.location}</span>
                        </>
                      )}
                    </div>

                  <p class={`text-slate-300 leading-relaxed mb-6 font-medium ${isLeft ? 'md:ml-auto' : ''}`}>
                    {item.description}
                  </p>

                  {item.tech && item.tech.length > 0 && (
                    <div class={`flex mt-2 ${isLeft ? 'md:justify-end' : 'md:justify-start'}`}>
                      <AvatarCircles 
                        client:visible 
                        className={isLeft ? 'flex-row-reverse -space-x-reverse space-x-[-16px] md:-space-x-4 md:flex-row' : ''}
                        avatarUrls={item.tech.map(t => `https://skillicons.dev/icons?i=${t === 'tailwindcss' ? 'tailwind' : t === 'js' ? 'javascript' : t === 'bootstrap' ? 'bootstrap' : t}`)} 
                      />
                    </div>
                  )}
                  </ScrollHighlight>
                </div>
              </ScrollReveal>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
