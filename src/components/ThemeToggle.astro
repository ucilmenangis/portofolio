---
import Icon from "./Icon.astro";
---

<button
  aria-label="Toggle dark mode"
  class="theme-toggle-btn relative w-10 h-10 rounded-full border border-slate-200 dark:border-slate-700 bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm flex items-center justify-center cursor-pointer transition-all duration-300 hover:scale-110 hover:shadow-md"
>
  <!-- Sun icon -->
  <Icon
    name="sun"
    class="sun-icon w-5 h-5 text-amber-500 absolute transition-all duration-300 rotate-0 scale-100 dark:-rotate-90 dark:scale-0"
  />

  <!-- Moon icon -->
  <Icon
    name="moon"
    class="moon-icon w-5 h-5 text-primary-400 absolute transition-all duration-300 rotate-90 scale-0 dark:rotate-0 dark:scale-100"
  />
</button>

<script>
  // Astro automatically deduplicates this module script so it runs exactly once
  // per page, correctly mounting all ThemeToggle buttons!
  document.querySelectorAll(".theme-toggle-btn").forEach((button) => {
    button.addEventListener("click", () => {
      const html = document.documentElement;
      html.classList.toggle("dark");
      localStorage.setItem(
        "theme",
        html.classList.contains("dark") ? "dark" : "light",
      );
    });
  });
</script>
